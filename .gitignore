.omx/

# 환경 설정 파일 (실제 값 포함 — git 제외). .env.example만 추적.
.env
.env.dev
.env.beta
.env.prod
.env.local
.env.*.local

# TLS 인증서/키 (운영) — 절대 커밋 금지. README/.gitkeep만 추적.
docker/nginx/certs/*
!docker/nginx/certs/README.md
!docker/nginx/certs/.gitkeep

# 사내가 jfpage에서 복사한 top-level 인증서/개인키 — 절대 커밋 금지 (server.key 등)
certs/
*.key
*.crt
*.pem
!**/README.md

# OMC 상태/세션 파일 (스펙은 포함)
.omc/state/
.omc/logs/

# Claude Code 로컬 상태 (머신 전용 설정 + 에이전트 worktree 복사본 — 절대 커밋 금지)
.claude/

# macOS
.DS_Store

# Playwright/스크린샷 결과물 (CI 외 로컬)
.playwright-cli/
.playwright-mcp/
test-results/
playwright-report/
frontend/test-results/
frontend/playwright-report/

# 탐색용 디자인 mockup (throwaway)
