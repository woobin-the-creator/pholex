# ─────────────────────────────────────────────────────────────
# Pholex .env.example — copy to .env.dev and fill in
# ─────────────────────────────────────────────────────────────

# ── Adapter mode ──
# fake = Fake adapters (golden dataset only, no real internal data)
# real = Real adapters (사내 AI가 구현한 어댑터, requires T2 work complete)
ADAPTER_MODE=fake

# ── Auth ──
DEV_SSO_BYPASS=true
SESSION_COOKIE_SECURE=false

# ── DB ──
POSTGRES_DB=pholex
POSTGRES_USER=pholex
POSTGRES_PASSWORD=pholex
DATABASE_URL=postgresql+asyncpg://pholex:pholex@postgres:5432/pholex

# ── 미러 레포 (사내 환경에서만 채움) ──
# 빈 값 = 공식 레포 사용 (외부 인터넷 환경)
# 사내 = 사내 미러 URL로 채움 (사내 AI가 빌드 검증)
DOCKER_REGISTRY=
PIP_INDEX_URL=
PIP_TRUSTED_HOST=
APT_MIRROR=
NPM_REGISTRY_URL=
