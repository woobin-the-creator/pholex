SECRET_KEY=change-me

# Database / cache
POSTGRES_DB=pholex
POSTGRES_USER=pholex
POSTGRES_PASSWORD=change-me
DATABASE_URL=sqlite+aiosqlite:///./pholex.db
REDIS_URL=redis://redis:6379/0
SESSION_BACKEND=memory
SESSION_TTL_SECONDS=1209600
CACHE_TTL_SECONDS=5
WS_POLL_INTERVAL=1.0
COOKIE_SECURE=false

# App / routing
SSO_BASE_URL=http://localhost:8080

# OIDC SSO
SSO_IDP_ENTITY_ID=
SSO_CLIENT_ID=
SSO_CERT=
SSO_EMPLOYEE_ID_CLAIM=employee_id
SSO_EMPLOYEE_NUMBER_CLAIM=employee_number
SSO_USERNAME_CLAIM=username
SSO_EMAIL_CLAIM=email
SSO_AUTH_CLAIM=auth

# Dev SSO bypass
DEV_SSO_BYPASS=true
DEV_SSO_USER_ID=test001
DEV_SSO_USERNAME=테스트엔지니어
DEV_SSO_EMPLOYEE_NUMBER=99999
DEV_SSO_EMAIL=test@dev.local
DEV_SSO_AUTH=ENGINEER

# Legacy note: older docs mention LDAP_SERVER, but MVP auth follows docs/auth.md OIDC flow.
LDAP_SERVER=ldap://ldap.internal
