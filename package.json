{
  "name": "pholex-verification-harness",
  "private": true,
  "scripts": {
    "test:backend": "PYTHONPATH=backend pytest backend/tests -q",
    "test:frontend": "npm --prefix frontend run test",
    "typecheck:frontend": "npm --prefix frontend run typecheck",
    "lint:frontend": "npm --prefix frontend run lint",
    "test:smoke": "bash scripts/test_smoke.sh",
    "test:e2e": "playwright test e2e/pholex-mvp-slot1.spec.ts",
    "verify:frontend": "npm --prefix frontend run lint && npm --prefix frontend run typecheck && npm --prefix frontend run test"
  }
}
